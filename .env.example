# Environment Configuration for Perfient MVP

# ============================================
# Mock Mode (Local Development)
# ============================================
# Set to 'true' for local development without Firestore
# Set to 'false' for production with real Firestore backend
MOCK_MODE=true

# ============================================
# API Keys (Required for market data)
# ============================================
# Tiingo API key for stock market data
# Get your free key at: https://www.tiingo.com/
TIINGO_API_KEY=your_tiingo_api_key_here

# FMP API key (Financial Modeling Prep) - optional
FMP_API_KEY=your_fmp_api_key_here

# ============================================
# Google Cloud (Production only)
# ============================================
# Path to your Google Cloud service account JSON
# Only required when MOCK_MODE=false
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================
# Encryption (Production only)
# ============================================
# KMS key for encrypting sensitive user data
# Only required when MOCK_MODE=false
# ENCRYPTION_KEY_ID=projects/YOUR_PROJECT/locations/YOUR_LOCATION/keyRings/YOUR_RING/cryptoKeys/YOUR_KEY

# ============================================
# Development Settings
# ============================================
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable debug traces
DEBUG=false
